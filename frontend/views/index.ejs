<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LS Clip — Shareable Clips &amp; Snippets</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/app.css">
</head>
<body data-theme="white">
<div class="app">

<header>
  <a class="logo" href="/">
    <div class="logo-mark">&#8249;LS&#8250;</div>
    <div>
      <div class="brand-title">Clip</div>
      <div class="brand-sub">Logic Shift</div>
    </div>
  </a>
  <div class="header-right">
    <a class="nav-link" href="/help">Help</a>
    <a class="nav-link" href="/about">About</a>
    <div class="theme-toggle">
      <button class="theme-btn active" data-theme="white" onclick="LSClip.setTheme('white')">White</button>
      <button class="theme-btn" data-theme="dark" onclick="LSClip.setTheme('dark')">Dark</button>
      <button class="theme-btn" data-theme="paper" onclick="LSClip.setTheme('paper')">Paper</button>
    </div>
  </div>
</header>

<main>
  <div class="landing fade-in">
    <div>
      <div class="hero-label">Shareable Clips &amp; Snippets</div>
      <div style="height:14px"></div>
      <h1 class="hero-title">Your clipboard,<br><em>your URL.</em></h1>
      <div style="height:14px"></div>
      <p class="hero-sub">Create a clip at any custom URL. Share rich text, code, notes, files &mdash; anything. No account needed.</p>
    </div>

    <div class="slug-form">
      <div class="slug-row" id="slugRow">
        <div class="slug-prefix" id="slugPrefix"><%= BASE_URL %>/</div>
        <input class="slug-input" id="slugInput" type="text" value="" placeholder="my-clip" maxlength="32" autocomplete="off" spellcheck="false">
      </div>
      <div class="hint-text" id="slugHint">&nbsp;</div>
      <div style="display:flex;gap:10px;">
        <button class="btn btn-primary" id="goBtn" onclick="goToClip()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Create / Open Clip
        </button>
        <button class="btn btn-ghost" onclick="randomSlug()">Random</button>
      </div>
    </div>

    <div class="features">
      <div class="feature">
        <div class="feature-icon">&#128279;</div>
        <div class="feature-title">Custom URLs</div>
        <div class="feature-desc">Pick any slug. Share the URL with anyone.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">&#128275;</div>
        <div class="feature-title">Password Lock</div>
        <div class="feature-desc">Full Public, Read-only, or Private.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">&#9889;</div>
        <div class="feature-title">Auto-save</div>
        <div class="feature-desc">Saves as you type. Ctrl+S too.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">&#128221;</div>
        <div class="feature-title">Rich Text</div>
        <div class="feature-desc">Bold, lists, links, colors, code.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">&#128206;</div>
        <div class="feature-title">File Attachments</div>
        <div class="feature-desc">One file per clip, 20 MB max, 3-day expiry.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">&#128259;</div>
        <div class="feature-title">Rolling Expiry</div>
        <div class="feature-desc">Resets on each visit. Or single-view.</div>
      </div>
    </div>
  </div>
</main>

<footer>
  <span>Self-hosted &middot; Minimal &middot; Open Source</span>
  <span></span>
</footer>

</div>

<div id="toasts"></div>

<script src="/js/app.js"></script>
<script>
LSClip.init({ BASE_URL: '<%= BASE_URL %>' });
LSClip.restoreTheme();
document.getElementById('slugInput').value = LSClip.generateSlug();
updateHint(LSClip.generateSlug());

let slugCheckTimer = null;
const slugInput = document.getElementById('slugInput');
slugInput.addEventListener('input', () => {
  let v = slugInput.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
  slugInput.value = v;
  clearTimeout(slugCheckTimer);
  if (v.length >= 3) {
    slugCheckTimer = setTimeout(() => checkSlug(v), 400);
  } else if (v.length > 0) {
    setHint('\u2722 Too short \u2014 minimum 3 characters', 'error');
  } else {
    setHint('&nbsp;', '');
  }
});

slugInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') goToClip();
});

function goToClip() {
  const slug = slugInput.value.trim().toLowerCase();
  if (slug.length < 3) {
    setHint('\u2717 Slug must be at least 3 characters', 'error');
    return;
  }
  window.location.href = '/' + encodeURIComponent(slug);
}

async function checkSlug(slug) {
  setHint('Checking...', '');
  try {
    const r = await fetch('/api/check/' + encodeURIComponent(slug));
    const data = await r.json();
    if (data.exists) {
      if (data.access_mode === 'private') {
        setHint('\U0001f512 Exists \u2014 password protected', 'error');
      } else {
        setHint('\u2713 Exists \u2014 click to open', 'ok');
      }
    } else {
      setHint('\u2726 New clip \u2014 will be created', 'ok');
    }
  } catch {
    setHint('Could not check availability', 'error');
  }
}

function setHint(text, cls) {
  const h = document.getElementById('slugHint');
  h.innerHTML = text;
  h.className = 'hint-text ' + cls;
}

function randomSlug() {
  const s = LSClip.generateSlug();
  slugInput.value = s;
  updateHint(s);
}

function updateHint(slug) {
  setHint('\u2726 New clip \u2014 will be created', 'ok');
}
</script>
</body>
</html>